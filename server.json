  "repository": {
    "url": "https://github.com/cocaxcode/devflow-mcp",
    "source": "github"
  },
  "version": "0.1.6",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@cocaxcode/devflow-mcp",
      "version": "0.1.6",
      "runtime": "node",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
